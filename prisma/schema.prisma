generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PATIENT
  DOCTOR
  INTERN
  ADMIN
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_APPROVAL
}

enum RegistrationStatus {
  IN_PROGRESS
  COMPLETED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
}

model User {
  id                 String             @id @default(uuid())
  fullName           String
  email              String             @unique
  passwordHash       String
  role               UserRole
  accountStatus      AccountStatus      @default(ACTIVE)
  registrationStatus RegistrationStatus @default(COMPLETED)
  isEmailVerified    Boolean            @default(false)
  profilePhotoUrl    String?
  lastLoginAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  patientProfile     PatientProfile?
  doctorProfile      DoctorProfile?
  internProfile      InternProfile?
}

model PatientProfile {
  id                 String      @id @default(uuid())
  userId             String      @unique
  gender             Gender?
  location           String?
  phoneNumber        String?
  whatsappNumber     String?
  age                Int?
  heightCm           Float?
  weightKg           Float?
  bloodGroup         BloodGroup?
  socialHandle       String?
  isDefencePersonnel Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  phoneNumber       String?
  specialization    String?
  qualification     String?
  licenseNumber     String?   @unique
  yearsOfExperience Int?
  hospitalName      String?
  clinicAddress     String?
  isApproved        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InternProfile {
  id             String    @id @default(uuid())
  userId         String    @unique
  phoneNumber    String?
  universityName String?
  specialization String?
  semester       Int?
  year           Int?
  isApproved     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}