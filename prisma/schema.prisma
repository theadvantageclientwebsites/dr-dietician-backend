generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PATIENT
  DOCTOR
  INTERN
  ADMIN
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_APPROVAL
}

enum RegistrationStatus {
  IN_PROGRESS
  COMPLETED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum AppointmentType {
  ONLINE
  IN_PERSON
}

model User {
  id                 String             @id @default(uuid())
  fullName           String
  email              String             @unique
  passwordHash       String
  role               UserRole
  accountStatus      AccountStatus      @default(ACTIVE)
  registrationStatus RegistrationStatus @default(COMPLETED)
  isEmailVerified    Boolean            @default(false)
  profilePhotoUrl    String?
  lastLoginAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  patientProfile        PatientProfile?
  doctorProfile         DoctorProfile?
  internProfile         InternProfile?
  appointmentsAsPatient Appointment[]      @relation("PatientAppointments")
  appointmentsAsDoctor  Appointment[]      @relation("DoctorAppointments")
  courseEnrollments     CourseEnrollment[] @relation("InternEnrollments")
  orders                Order[]            @relation("PatientOrders")
}

model Appointment {
  id        String            @id @default(uuid())
  patientId String
  doctorId  String
  dateTime  DateTime
  type      AppointmentType   @default(ONLINE)
  status    AppointmentStatus @default(PENDING)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  patient   User @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctor    User @relation("DoctorAppointments",  fields: [doctorId],  references: [id], onDelete: Cascade)
}

enum DigitalProductStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

model DigitalProduct {
  id           String               @id @default(uuid())
  title        String
  category     String
  status       DigitalProductStatus @default(DRAFT)
  price        Float                @default(0)
  description  String?
  fileUrl      String?
  thumbnailUrl String?
  author       String?
  pageCount    Int?
  language     String               @default("English")
  isFree       Boolean              @default(false)
  totalSales   Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model Package {
  id            String   @id @default(uuid())
  name          String
  category      String
  description   String?
  price1Month   Float
  price3Months  Float
  price6Months  Float
  features      String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PatientProfile {
  id                 String      @id @default(uuid())
  userId             String      @unique
  gender             Gender?
  location           String?
  phoneNumber        String?
  whatsappNumber     String?
  age                Int?
  heightCm           Float?
  weightKg           Float?
  bloodGroup         BloodGroup?
  socialHandle       String?
  isDefencePersonnel Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  phoneNumber       String?
  specialization    String?
  qualification     String?
  licenseNumber     String?   @unique
  yearsOfExperience Int?
  hospitalName      String?
  clinicAddress     String?
  isApproved        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InternProfile {
  id             String    @id @default(uuid())
  userId         String    @unique
  phoneNumber    String?
  universityName String?
  specialization String?
  semester       Int?
  year           Int?
  isApproved     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── LMS Models ───────────────────────────────────────────────────────────────

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  FAILED
}

model Course {
  id             String   @id @default(uuid())
  title          String
  description    String?
  thumbnailUrl   String?
  category       String?
  instructor     String?
  duration       String?
  minSemester    Int?
  minYear        Int?
  hasFinalTest   Boolean  @default(false)
  isActive       Boolean  @default(true)
  totalLessons   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lessons     Lesson[]
  enrollments CourseEnrollment[]
}

model Lesson {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  content     String?
  videoUrl    String?
  fileUrl     String?
  order       Int
  durationMin Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course          Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress  LessonProgress[]
}

model CourseEnrollment {
  id           String           @id @default(uuid())
  internId     String
  courseId     String
  status       EnrollmentStatus @default(ENROLLED)
  progress     Float            @default(0)
  enrolledAt   DateTime         @default(now())
  completedAt  DateTime?
  updatedAt    DateTime         @updatedAt

  intern          User             @relation("InternEnrollments", fields: [internId], references: [id], onDelete: Cascade)
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress  LessonProgress[]

  @@unique([internId, courseId])
}

model LessonProgress {
  id           String   @id @default(uuid())
  enrollmentId String
  lessonId     String
  isCompleted  Boolean  @default(false)
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
}

// ─── Payment Models ───────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderItemType {
  PACKAGE
  DIGITAL_PRODUCT
  SERVICE
}

enum PackageDuration {
  ONE_MONTH
  THREE_MONTHS
  SIX_MONTHS
}

model Order {
  id                 String          @id @default(uuid())
  patientId          String
  itemType           OrderItemType
  itemId             String
  itemName           String
  amount             Float
  currency           String          @default("INR")
  duration           PackageDuration?
  status             OrderStatus     @default(PENDING)
  razorpayOrderId    String?         @unique
  razorpayPaymentId  String?         @unique
  razorpaySignature  String?
  paidAt             DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  patient   User @relation("PatientOrders", fields: [patientId], references: [id], onDelete: Cascade)
}
